# ── Dockerfile — API données RouteZone ───────────────────────────
FROM python:3.11-slim

WORKDIR /app

COPY docker/requirements_api_data.txt .
RUN pip install --no-cache-dir -r requirements_api_data.txt

COPY src/api_data/main.py .

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
